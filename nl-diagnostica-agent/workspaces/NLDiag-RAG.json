    {
      "parameters": {
        "jsCode": "// Converge texto de PDF / OCR / documento / planilha (1 item por arquivo).\nconst ctx = $('Set File Context').first().json;\nconst items = $input.all();\nconst texts = items\n  .map(i => i.json.text != null ? i.json.text : (i.json.data != null ? i.json.data : i.json.ocr_text))\n  .filter(v => v != null && String(v).trim() !== '');\nlet content = '';\nif (texts.length) {\n  content = texts.join('\\n');\n} else {\n  // linhas de planilha/csv → texto chave: valor\n  for (const it of items) {\n    const row = it.json || {};\n    const parts = [];\n    for (const k in row) {\n      const v = row[k];\n      if (v != null && v !== '') parts.push(k + ': ' + v);\n    }\n    if (parts.length) content += parts.join('. ') + '\\n';\n  }\n}\ncontent = content\n  .replace(/[\\u0000-\\u0008\\u000B\\u000C\\u000E-\\u001F]/g, ' ')\n  .replace(/[ \\t]+/g, ' ')\n  .slice(0, 50000);\nif (content.replace(/\\s+/g, '').length < 20) {\n  throw new Error('Documento sem texto utilizável: ' + (ctx.title || ctx.file_id) + ' (file_id=' + ctx.file_id + '). Se for digitalização, configure o OCR.');\n}\nreturn [{ json: {\n  file_id: ctx.file_id,\n  title: ctx.title,\n  code: ctx.code,\n  url: ctx.url,\n  mime_type: ctx.mime_type,\n  source: 'drive',\n  content_text: content\n} }];"
      },
