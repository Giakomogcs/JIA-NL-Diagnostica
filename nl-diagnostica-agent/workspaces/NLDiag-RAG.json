      "parameters": {
        "jsCode": "// Define metadados do arquivo do Drive e classifica o tipo (kind).\nconst f = $json;\nconst name = f.name || f.title || 'documento';\nconst mime = f.mimeType || '';\nconst dot = name.lastIndexOf('.');\nconst ext = dot > 0 ? name.slice(dot + 1).toLowerCase() : '';\nlet kind = 'text';\nif (mime.includes('pdf') || ext === 'pdf') kind = 'pdf';\nelse if (mime.includes('spreadsheet') || mime.includes('excel') || ext === 'xlsx' || ext === 'xls') kind = 'xlsx';\nelse if (mime.includes('csv') || ext === 'csv') kind = 'csv';\nreturn {\n  file_id: f.id,\n  title: name,\n  code: dot > 0 ? name.slice(0, dot) : name,\n  mime_type: mime,\n  url: f.webViewLink || null,\n  source: 'drive',\n  kind\n};"
      },
