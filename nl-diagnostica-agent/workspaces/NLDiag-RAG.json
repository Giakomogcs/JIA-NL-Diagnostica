    {
      "parameters": {
        "jsCode": "// Extrai o texto do retorno do OCR (Responses API ou Chat Completions).\nconst r = $json;\nlet text = '';\ntry {\n  if (Array.isArray(r.output)) {\n    for (const o of r.output) {\n      if (Array.isArray(o.content)) {\n        for (const c of o.content) { if (c.text) text += c.text; }\n      }\n    }\n  }\n  text = text || r.output_text || (r.choices && r.choices[0] && r.choices[0].message && r.choices[0].message.content) || '';\n} catch (e) {}\nreturn { ocr_text: text };"
      },
