    {
      "parameters": {
        "jsCode": "// Normaliza o resultado do Drive (update OU upload) para o shape do Loop Over Items.\n// source='chat' quando há session_id (anexo de conversa) → indexado só naquela sessão.\nconst drive = $input.first().json || {};\nconst ctx = $('Decide Replace or Create').first().json;\nconst fileId = drive.id || ctx.existing_file_id;\nif (!fileId) throw new Error('Drive não retornou file_id após upload/update.');\nconst dot = ctx.filename.lastIndexOf('.');\nconst code = dot > 0 ? ctx.filename.substring(0, dot) : ctx.filename;\nreturn [{\n  json: {\n    id: fileId,\n    name: ctx.filename,\n    mimeType: drive.mimeType || ctx.mime_type,\n    webViewLink: drive.webViewLink || ctx.existing_web_view_link || null,\n    code,\n    source: ctx.session_id ? 'chat' : 'upload',\n    session_id: ctx.session_id || null\n  }\n}];"
      },
