    {
      "parameters": {
        "jsCode": "// Reindex: aceita { file_id } | { file_ids:[...] } | { ids:[...] }.\n// Sem ids → reprocessa a PASTA inteira do Drive (comportamento antigo).\nconst b = ($input.first().json.body) || $input.first().json || {};\nlet ids = [];\nif (Array.isArray(b.file_ids)) ids = b.file_ids;\nelse if (Array.isArray(b.ids)) ids = b.ids;\nelse if (b.file_id) ids = [b.file_id];\nelse if (b.id) ids = [b.id];\nids = ids.map(x => String(x || '').trim()).filter(Boolean);\nreturn [{ json: { mode: ids.length ? 'ids' : 'folder', ids, ids_csv: ids.map(s => s.replace(/[^a-zA-Z0-9_\\-\\.]/g, '')).join(',') } }];"
      },
