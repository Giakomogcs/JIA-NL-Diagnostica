    {
      "parameters": {
        "jsCode": "// Upload unitário (arquivo real, multipart). Extrai filename do binário e\n// session_id opcional (quando enviado pelo chat → indexa só naquela conversa).\nconst item = $input.first();\nconst body = item.json.body || item.json || {};\nconst q = item.json.query || {};\nconst bin = item.binary && (item.binary.data || item.binary[Object.keys(item.binary)[0]]);\nif (!bin) throw new Error('Arquivo \"data\" não enviado no multipart.');\nconst filename = bin.fileName || body.filename || '';\nif (!filename) throw new Error('Não foi possível determinar o nome do arquivo.');\nconst session_id = (body.session_id || body.sessionId || q.sessionId || q.session_id || '').toString().trim() || null;\nitem.json = { ...item.json, filename, mime_type: bin.mimeType || 'application/octet-stream', session_id };\nreturn item;"
      },
