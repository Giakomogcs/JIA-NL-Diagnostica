    {
      "parameters": {
        "jsCode": "// Mantém o shape esperado pelo Loop Over Items (reprocessa do mesmo file_id no Drive).\nconst rows = $input.all();\nif (rows.length === 0) throw new Error('Nenhum documento encontrado para os file_ids fornecidos.');\nreturn rows.map(r => ({\n  json: {\n    id: r.json.id,\n    name: r.json.name,\n    mimeType: r.json.mimeType,\n    webViewLink: r.json.webViewLink,\n    code: r.json.code,\n    source: 'drive',\n    session_id: null\n  }\n}));"
      },
