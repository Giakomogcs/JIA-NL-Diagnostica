        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"licitacoesDescarte\": [\n    {\n      \"idLicitacao\": {{ $json.idLicitacao }},\n      \"motivos\": [ { \"motivo\": \"{{ $json.motivoEffecti }}\", \"descricao\": \"{{ ($json.motivo || '').replace(/\\\"/g,'') }}\" } ]\n    }\n  ]\n}",
