      "webhookId": "nldiag-effecti-sync"
    },
    {
      "parameters": {
        "jsCode": "// Recebe a decisão já persistida no Supabase e a empurra para a Effecti.\n// Body: { idLicitacao, acao ('aceitar'|'recusar'), motivo?, motivoEffecti? }\nconst b = $input.first().json.body ?? $input.first().json ?? {};\nconst idLicitacao = Number(b.idLicitacao);\nconst acao = (b.acao || '').toString().trim();\nif (!idLicitacao) throw new Error('idLicitacao é obrigatório');\nif (!['aceitar','recusar'].includes(acao)) throw new Error('acao inválida');\nconst MOTIVOS = ['FALTA_CAPACIDADE_TECNICA','LOCALIDADE_ENTREGA','VALOR_ESTIMADO_BAIXO','DOCUMENTACAO_INSUFICIENTE','PRAZO_ENTREGA_CURTO','OUTROS'];\nlet motivoEffecti = (b.motivoEffecti || 'OUTROS').toString().toUpperCase();\nif (!MOTIVOS.includes(motivoEffecti)) motivoEffecti = 'OUTROS';\nreturn { idLicitacao, acao, motivo: (b.motivo || '').toString(), motivoEffecti };"
      },
      "id": "d46c75bb-c474-4eaa-bb94-3af563ee0745",
      "name": "Prepare Sync",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [704, 752]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "version": 2
          },
          "combinator": "and",
          "conditions": [
            {
              "leftValue": "={{ $json.acao }}",
              "rightValue": "aceitar",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ]
        },
        "options": {}
      },
      "id": "0a28850b-8861-4a21-bfe5-79b54551171e",
      "name": "Aceitar?",
