      "id": "89b4c842-a749-4881-9b41-428ea57c6fee",
      "name": "Effecti: descartar c/ motivo",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1152, 864]
    },
    {
      "parameters": {
        "jsCode": "// neverError=true mantém o fluxo vivo mesmo se a Effecti falhar.\n// Aqui decidimos se deu certo (2xx) antes de marcar como sincronizado.\nconst r = $input.first().json;\nconst status = Number(r.statusCode ?? 0);\nconst ok = status >= 200 && status < 300;\nconst body = typeof r.body === 'string' ? r.body : JSON.stringify(r.body ?? '');\nreturn { ok, statusCode: status, effectiBody: (body || '').slice(0, 500) };"
      },
