      "id": "a62409fb-5d50-4d71-82f7-ad2a4bc91ce6",
      "name": "Webhook - Delete Doc",
      "position": [2384, 992],
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "webhookId": "nldiag-rag-doc-delete"
    },
    {
      "parameters": {
        "jsCode": "const b = $input.first().json || {};\nconst body = b.body || b;\nconst q = b.query || b.queryString || {};\nconst fileId = body.file_id || body.id || q.file_id || q.id;\nif (!fileId) throw new Error('file_id is required');\nreturn { fileId };"
      },
      "id": "ea571b63-412e-4ea3-9129-b49f90daa709",
      "name": "Extract file_id (delete)",
      "position": [2608, 992],
      "type": "n8n-nodes-base.code",
      "typeVersion": 2
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH purged AS (\n  DELETE FROM nl_documents WHERE metadata->>'file_id' = '{{ $json.fileId }}' RETURNING 1\n), purged_rows AS (\n  DELETE FROM nl_document_rows WHERE dataset_id = '{{ $json.fileId }}' RETURNING 1\n)\nDELETE FROM nl_document_metadata WHERE file_id = '{{ $json.fileId }}' RETURNING file_id AS deleted_file_id;",
        "options": {}
      },
      "id": "2b9ca573-267a-43b9-abad-1a277a6118d4",
      "name": "Delete Doc from DB",
