      "typeVersion": 2,
      "webhookId": "nldiag-rag-docs-list"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  m.file_id AS id, m.file_id, m.title, m.code, m.url, m.source, m.mime_type,\n  COALESCE((SELECT COUNT(*) FROM nl_documents d WHERE d.metadata->>'file_id' = m.file_id), 0) AS chunk_count,\n  m.created_at, m.updated_at AS last_indexed_at\nFROM nl_document_metadata m\nWHERE m.source IS DISTINCT FROM 'chat'\nORDER BY COALESCE(m.code, m.title, m.file_id);",
        "options": {}
      },
      "id": "49d787bc-4efc-440f-83ef-81f8da3964c2",
      "name": "List Docs from DB",
      "position": [2608, 784],
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "credentials": {
        "postgres": {
          "id": "jFjeYH6Nt3aRNkoM",
          "name": "Supabase_database"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const docs = $input.all().map(i => i.json);\nreturn [{ json: { docs } }];"
      },
      "id": "eb9805e9-1d91-4593-aa46-4b6cebe7f99d",
